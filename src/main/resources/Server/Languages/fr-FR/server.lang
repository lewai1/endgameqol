items.Endgame_Accessory_Pouch.name = Sac à accessoires
items.Endgame_Accessory_Pouch.description = Une bourse renforcée fabriquée à partir des meilleurs matériaux endgame. Contient jusqu'à <color is="#FFD700">5 accessoires</color> qui confèrent des bonus passifs de combat.\n<color is="#b8860b">Clic Droit</color> pour ouvrir.
items.Endgame_Accessory_Frostwalkers.name = Marcheurs de Glace
items.Endgame_Accessory_Frostwalkers.description = <color is="#b8860b">Accessoire — à ranger dans la bourse à breloques</color>\nDes bottes imprégnées de magie de glace, gelant l'eau sous les pieds du porteur.\n<color is="#05c09a">Effet :</color> <color is="#66ccff">Marcher sur l'eau (la glace fond après 3s)</color>
items.Endgame_Accessory_Ocean_Striders.name = Arpenteurs de l'Océan
items.Endgame_Accessory_Ocean_Striders.description = <color is="#b8860b">Accessoire — à ranger dans la bourse à breloques</color>\nDes nageoires enchantées bénies par la mer, propulsant le porteur à travers l'eau à une vitesse incroyable.\n<color is="#05c09a">Effet :</color> <color is="#00BFFF">2x vitesse de nage dans l'eau</color>
items.Endgame_Accessory_Void_Amulet.name = Amulette du Vide
items.Endgame_Accessory_Void_Amulet.description = <color is="#b8860b">Accessoire — à ranger dans la bourse à breloques</color>\nUne amulette pulsant d'énergie du vide. Quand un coup fatal devrait vous terrasser, survivez à 1 PV avec 3 secondes d'invulnérabilité.\n<color is="#05c09a">Effet :</color> <color is="#800080">Tromper la mort (5min CD)</color>
items.Endgame_Accessory_Blazefist.name = Poing de Braise
items.Endgame_Accessory_Blazefist.description = <color is="#b8860b">Accessoire — à ranger dans la bourse à breloques</color>\nUn poing forgé dans le feu de dragon, embrasant tous ceux qui osent se tenir près de votre cible.\n<color is="#05c09a">Effet :</color> <color is="#ff5555">Brûlure sur la cible + feu AOE 3m</color>
items.Endgame_Accessory_Pocket_Garden.name = Jardin de Poche
items.Endgame_Accessory_Pocket_Garden.description = <color is="#b8860b">Accessoire — à ranger dans la bourse à breloques</color>\nUn charme vivant contenant un jardin miniature qui irradie une énergie curative.\n<color is="#05c09a">Effet :</color> <color is="#2E8B57">+1 PV/sec de régénération passive</color>
items.Endgame_Accessory_Hedera_Seed.name = Graine d'Hedera
items.Endgame_Accessory_Hedera_Seed.description = <color is="#b8860b">Accessoire — à ranger dans la bourse à breloques</color>\nUne graine dormante d'Hedera, ripostant contre ceux qui oseraient blesser son porteur avec des racines enlaçantes.\n<color is="#05c09a">Effet :</color> <color is="#2E8B57">15% de chance d'enraciner l'attaquant pendant 2s</color>
