items.Endgame_Void_Core_Light.name = Nucleo Luminoso del Vacio
items.Build_Lightsource_Plum.name = Luz Ciruela
items.Endgame_Accessory_Pouch.name = Bolsa de Amuletos
items.Endgame_Accessory_Pouch.description = Una bolsa reforzada fabricada con los mejores materiales endgame. Contiene hasta <color is="#FFD700">5 accesorios</color> que otorgan bonificaciones pasivas de combate.\n<color is="#b8860b">Clic Derecho</color> para abrir.
items.Endgame_Accessory_Frostwalkers.name = Caminantes de Hielo
items.Endgame_Accessory_Frostwalkers.description = Botas imbuidas con magia de hielo, congelando el agua bajo los pies del portador.\n<color is="#05c09a">Efecto:</color> <color is="#66ccff">Caminar sobre el agua (el hielo se derrite tras 3s)</color>
items.Endgame_Accessory_Ocean_Striders.name = Zancadores del Oceano
items.Endgame_Accessory_Ocean_Striders.description = Aletas encantadas bendecidas por el mar, propulsando al portador por el agua a velocidad increible.\n<color is="#05c09a">Efecto:</color> <color is="#00BFFF">2x velocidad de nado en el agua</color>
items.Endgame_Accessory_Void_Amulet.name = Amuleto del Vacio
items.Endgame_Accessory_Void_Amulet.description = Un amuleto pulsando con energia del vacio. Cuando un golpe fatal te derribaria, sobrevive con 1 PV y 3 segundos de invulnerabilidad.\n<color is="#05c09a">Efecto:</color> <color is="#800080">Enganar a la muerte (5min CD)</color>
items.Endgame_Accessory_Blazefist.name = Puno de Brasa
items.Endgame_Accessory_Blazefist.description = Un puno forjado en fuego de dragon, incendiando a todos los que se atreven a estar cerca de tu objetivo.\n<color is="#05c09a">Efecto:</color> <color is="#ff5555">Quemadura al objetivo + fuego AOE 3m</color>
items.Endgame_Accessory_Pocket_Garden.name = Jardin de Bolsillo
items.Endgame_Accessory_Pocket_Garden.description = Un amuleto viviente que contiene un jardin en miniatura que irradia energia curativa.\n<color is="#05c09a">Efecto:</color> <color is="#2E8B57">+1 PV/seg de regeneracion pasiva</color>
items.Endgame_Accessory_Hedera_Seed.name = Semilla de Hedera
items.Endgame_Accessory_Hedera_Seed.description = Una semilla dormida de Hedera, que responde contra quienes osen herir a su portador con raices enredadoras.\n<color is="#05c09a">Efecto:</color> <color is="#2E8B57">15% de probabilidad de enraizar al atacante durante 2s</color>
