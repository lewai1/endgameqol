Group {
  LayoutMode: Center;

  Group #GamePanel {
    Background: #0a0a12;
    Anchor: (Width: 500, Height: 570);
    LayoutMode: Top;
    Padding: (Left: 10, Right: 10, Top: 10, Bottom: 10);

    Group #Header {
      LayoutMode: Left;
      Anchor: (Height: 32);
      Padding: (Left: 20, Right: 20);

      Label #Title {
        Style: (FontSize: 20, TextColor: #00ff41);
        Text: "SNAKE";
        Anchor: (Width: 220);
      }

      Label #Score {
        Style: (FontSize: 20, TextColor: #00ff41, Alignment: End);
        Text: "Score: 0";
        Anchor: (Width: 220);
      }
    }

    Group #Spacer1 { Anchor: (Height: 6); }

    Group #GridWrapper {
      LayoutMode: Center;
      Background: #080810;
      Anchor: (Height: 404);
      Padding: (Full: 2);

