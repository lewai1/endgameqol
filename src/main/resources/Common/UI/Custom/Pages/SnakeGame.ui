    Group #Spacer2 { Anchor: (Height: 8); }

    Group #Controls {
      LayoutMode: Left;
      Anchor: (Height: 38);
      Padding: (Left: 20);

      TextButton #BtnUp {
        Anchor: (Width: 60, Height: 34);
        Text: "W";
        Background: #1a2a1a;
      }

      Group #Sp3 { Anchor: (Width: 6); }

      TextButton #BtnLeft {
        Anchor: (Width: 60, Height: 34);
        Text: "A";
        Background: #1a2a1a;
      }

      Group #Sp4 { Anchor: (Width: 6); }

      TextButton #BtnDown {
        Anchor: (Width: 60, Height: 34);
        Text: "S";
        Background: #1a2a1a;
      }

      Group #Sp5 { Anchor: (Width: 6); }

      TextButton #BtnRight {
        Anchor: (Width: 60, Height: 34);
        Text: "D";
        Background: #1a2a1a;
      }

      Group #Sp6 { Anchor: (Width: 14); }

      TextButton #BtnRetry {
        Anchor: (Width: 80, Height: 34);
        Text: "Retry";
        Background: #2d5a2d;
        Visible: false;
      }
    }

    Group #Spacer3 { Anchor: (Height: 6); }

    Group #KeyRow {
      LayoutMode: Left;
      Anchor: (Height: 30);
      Padding: (Left: 20);

      Label #KeyHint {
        Style: (FontSize: 12, TextColor: #336633);
        Text: "Type here to use keyboard:";
        Anchor: (Width: 200, Height: 28);
      }

      TextField #KeyInput {
        AutoFocus: true;
        MaxLength: 256;
        Anchor: (Width: 60, Height: 28);
        Background: #161620;
        PlaceholderText: "...";
      }
    }

    Group #Spacer4 { Anchor: (Height: 4); }

    Label #GameOverLabel {
      Style: (FontSize: 22, TextColor: #ff3333, Alignment: Center);
      Text: "GAME OVER";
      Visible: false;
      Anchor: (Height: 30);
    }
  }
}
