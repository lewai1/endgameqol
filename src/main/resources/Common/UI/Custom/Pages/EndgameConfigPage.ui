      // ==================== CRAFTING TAB ====================
      Group #ContentCrafting {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Padding: (Full: 16);
        Visible: false;

        Label { Style: (FontSize: 16, TextColor: #ffaa4a, RenderBold: true); Anchor: (Height: 24); Text: "Crafting Recipes"; }
        Label { Style: (FontSize: 12, TextColor: #6a7a8e); Anchor: (Height: 16); Text: "Enable or disable crafting recipe categories"; }
        Group { Anchor: (Height: 1); Background: #1e2a36; }
        Group { Anchor: (Height: 10); }

        // ---- Recipe Override Editor ----
        Label { Style: (FontSize: 16, TextColor: #ffaa4a, RenderBold: true); Anchor: (Height: 24); Text: "Recipe Overrides"; }
        Label { Style: (FontSize: 12, TextColor: #ff6666); Anchor: (Height: 16); Text: "Server restart required after changes"; }
        Group { Anchor: (Height: 1); Background: #1e2a36; }
        Group { Anchor: (Height: 8); }

        // Search bar
        Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 6);
          Label { Style: (FontSize: 13, TextColor: #96a9be, VerticalAlignment: Center); Anchor: (Width: 60); Text: "Search"; }
          $C.@TextField #RecipeSearch { FlexWeight: 1; Anchor: (Height: 28); Style: @InputFieldStyle; Background: #1a2633; Padding: (Horizontal: 8); PlaceholderText: "Filter recipes..."; }
          Group { Anchor: (Width: 6); }
          TextButton #RecipeSearchBtn { Anchor: (Width: 70, Height: 28); Text: "Search"; Style: @ApplyBtnStyle; }
          Group { Anchor: (Width: 4); }
          TextButton #RecipeSearchClear { Anchor: (Width: 60, Height: 28); Text: "Clear"; Style: @ActionBtnStyle; }
        }

        // Category filter buttons
        Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 8);
          TextButton #CatAll { Anchor: (Width: 70, Height: 28); Text: "All"; Style: @ActionActiveBtnStyle; }
          Group { Anchor: (Width: 4); }
          TextButton #CatPortals { Anchor: (Width: 80, Height: 28); Text: "Portals"; Style: @ActionBtnStyle; }
          Group { Anchor: (Width: 4); }
          TextButton #CatWeapons { Anchor: (Width: 86, Height: 28); Text: "Weapons"; Style: @ActionBtnStyle; }
          Group { Anchor: (Width: 4); }
          TextButton #CatArmor { Anchor: (Width: 76, Height: 28); Text: "Armor"; Style: @ActionBtnStyle; }
          Group { Anchor: (Width: 4); }
          TextButton #CatOther { Anchor: (Width: 76, Height: 28); Text: "Other"; Style: @ActionBtnStyle; }
          Group { FlexWeight: 1; }
          Label #CraftPageLabel { Style: (FontSize: 12, TextColor: #6a7a8e, VerticalAlignment: Center); Anchor: (Width: 80); Text: "1 / 1"; }
        }

        // ======= RECIPE LIST VIEW =======
        Group #CraftList { LayoutMode: Top; Visible: true;
          Group #Row0 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
            Label #Row0Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
            TextButton #Row0Toggle { Anchor: (Width: 80, Height: 26); Text: "ON"; Style: @ToggleOnStyle; }
            Group { Anchor: (Width: 6); }
            TextButton #Row0Edit { Anchor: (Width: 70, Height: 26); Text: "Edit"; Style: @ActionBtnStyle; }
          }
          Group #Row1 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
            Label #Row1Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
            TextButton #Row1Toggle { Anchor: (Width: 80, Height: 26); Text: "ON"; Style: @ToggleOnStyle; }
            Group { Anchor: (Width: 6); }
            TextButton #Row1Edit { Anchor: (Width: 70, Height: 26); Text: "Edit"; Style: @ActionBtnStyle; }
          }
          Group #Row2 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
            Label #Row2Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
            TextButton #Row2Toggle { Anchor: (Width: 80, Height: 26); Text: "ON"; Style: @ToggleOnStyle; }
            Group { Anchor: (Width: 6); }
            TextButton #Row2Edit { Anchor: (Width: 70, Height: 26); Text: "Edit"; Style: @ActionBtnStyle; }
          }
          Group #Row3 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
            Label #Row3Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
            TextButton #Row3Toggle { Anchor: (Width: 80, Height: 26); Text: "ON"; Style: @ToggleOnStyle; }
            Group { Anchor: (Width: 6); }
            TextButton #Row3Edit { Anchor: (Width: 70, Height: 26); Text: "Edit"; Style: @ActionBtnStyle; }
          }
          Group #Row4 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
            Label #Row4Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
            TextButton #Row4Toggle { Anchor: (Width: 80, Height: 26); Text: "ON"; Style: @ToggleOnStyle; }
            Group { Anchor: (Width: 6); }
            TextButton #Row4Edit { Anchor: (Width: 70, Height: 26); Text: "Edit"; Style: @ActionBtnStyle; }
          }
          Group #Row5 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
            Label #Row5Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
            TextButton #Row5Toggle { Anchor: (Width: 80, Height: 26); Text: "ON"; Style: @ToggleOnStyle; }
            Group { Anchor: (Width: 6); }
            TextButton #Row5Edit { Anchor: (Width: 70, Height: 26); Text: "Edit"; Style: @ActionBtnStyle; }
          }
          Group #Row6 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
            Label #Row6Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
            TextButton #Row6Toggle { Anchor: (Width: 80, Height: 26); Text: "ON"; Style: @ToggleOnStyle; }
            Group { Anchor: (Width: 6); }
            TextButton #Row6Edit { Anchor: (Width: 70, Height: 26); Text: "Edit"; Style: @ActionBtnStyle; }
          }
          Group #Row7 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
            Label #Row7Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
            TextButton #Row7Toggle { Anchor: (Width: 80, Height: 26); Text: "ON"; Style: @ToggleOnStyle; }
            Group { Anchor: (Width: 6); }
            TextButton #Row7Edit { Anchor: (Width: 70, Height: 26); Text: "Edit"; Style: @ActionBtnStyle; }
          }
          Group #Row8 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
            Label #Row8Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
            TextButton #Row8Toggle { Anchor: (Width: 80, Height: 26); Text: "ON"; Style: @ToggleOnStyle; }
            Group { Anchor: (Width: 6); }
            TextButton #Row8Edit { Anchor: (Width: 70, Height: 26); Text: "Edit"; Style: @ActionBtnStyle; }
          }
          Group #Row9 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
            Label #Row9Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
            TextButton #Row9Toggle { Anchor: (Width: 80, Height: 26); Text: "ON"; Style: @ToggleOnStyle; }
            Group { Anchor: (Width: 6); }
            TextButton #Row9Edit { Anchor: (Width: 70, Height: 26); Text: "Edit"; Style: @ActionBtnStyle; }
          }
          Group { Anchor: (Height: 6); }
          // Pagination
          Group { LayoutMode: Left; Anchor: (Height: 32);
            TextButton #CraftPrev { Anchor: (Width: 80, Height: 28); Text: "< Prev"; Style: @ActionBtnStyle; }
            Group { Anchor: (Width: 6); }
            TextButton #CraftNext { Anchor: (Width: 80, Height: 28); Text: "Next >"; Style: @ActionBtnStyle; }
          }
        }

        // ======= RECIPE DETAIL VIEW =======
        Group #CraftDetail { LayoutMode: Top; Visible: false;
          TextButton #DetailBack { Anchor: (Width: 110, Height: 28); Text: "< Back"; Style: @ActionBtnStyle; }
          Group { Anchor: (Height: 8); }
          Group { Background: #0b141f(0.84); LayoutMode: Top; Padding: (Full: 12);
            Label #DetailName { Style: (FontSize: 15, TextColor: #ffffff, RenderBold: true); Anchor: (Height: 22); Text: "Recipe Name"; }
            Group { Anchor: (Height: 4); }
            Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
              Label { Style: @LabelStyle; FlexWeight: 1; Text: "Enabled"; }
              TextButton #DetailToggle { Anchor: (Width: 80, Height: 28); Text: "ON"; Style: @ToggleOnStyle; }
            }
            Group { Anchor: (Height: 1); Background: #1e2a36; }
            Group { Anchor: (Height: 6); }
            // Output
            Label { Style: (FontSize: 13, TextColor: #4ade80, RenderBold: true); Anchor: (Height: 18); Text: "Output"; }
            Group { LayoutMode: Left; Anchor: (Height: 30, Bottom: 2);
              $C.@TextField #DetailOutputField { FlexWeight: 1; Anchor: (Height: 28); Style: @InputFieldStyle; Background: #1a2633; Padding: (Horizontal: 8); }
            }
            Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
              Label { Style: @SubLabelStyle; FlexWeight: 1; Text: "  Quantity"; }
              Label #DetailOutputQty { Style: @ValueStyle; Anchor: (Width: 50, Height: 24); Background: #061420; Text: "1"; }
              Group { Anchor: (Width: 6); }
              TextButton #DetailOutQtyDown { Anchor: (Width: 40, Height: 28); Text: "-"; Style: @AdjustBtnStyle; }
              Group { Anchor: (Width: 4); }
              TextButton #DetailOutQtyUp { Anchor: (Width: 40, Height: 28); Text: "+"; Style: @AdjustBtnStyle; }
            }
            Group { Anchor: (Height: 1); Background: #1e2a36; }
            Group { Anchor: (Height: 4); }
            // Inputs (up to 6 slots, hidden if unused)
            Label { Style: (FontSize: 13, TextColor: #55ccff, RenderBold: true); Anchor: (Height: 18); Text: "Inputs"; }
            Group #DetailIn0 { LayoutMode: Top; Anchor: (Bottom: 4); Visible: false;
              Group { LayoutMode: Left; Anchor: (Height: 28);
                $C.@TextField #DetailIn0Field { FlexWeight: 1; Anchor: (Height: 26); Style: @InputFieldStyle; Background: #1a2633; Padding: (Horizontal: 8); }
                Group { Anchor: (Width: 6); }
                Label { Style: @SubLabelStyle; Anchor: (Width: 30); Text: "Qty"; }
                Label #DetailIn0Qty { Style: @ValueStyle; Anchor: (Width: 50, Height: 24); Background: #061420; Text: "1"; }
                Group { Anchor: (Width: 4); }
                TextButton #DetailIn0Down { Anchor: (Width: 36, Height: 26); Text: "-"; Style: @AdjustBtnStyle; }
                Group { Anchor: (Width: 3); }
                TextButton #DetailIn0Up { Anchor: (Width: 36, Height: 26); Text: "+"; Style: @AdjustBtnStyle; }
              }
            }
            Group #DetailIn1 { LayoutMode: Top; Anchor: (Bottom: 4); Visible: false;
              Group { LayoutMode: Left; Anchor: (Height: 28);
                $C.@TextField #DetailIn1Field { FlexWeight: 1; Anchor: (Height: 26); Style: @InputFieldStyle; Background: #1a2633; Padding: (Horizontal: 8); }
                Group { Anchor: (Width: 6); }
                Label { Style: @SubLabelStyle; Anchor: (Width: 30); Text: "Qty"; }
                Label #DetailIn1Qty { Style: @ValueStyle; Anchor: (Width: 50, Height: 24); Background: #061420; Text: "1"; }
                Group { Anchor: (Width: 4); }
                TextButton #DetailIn1Down { Anchor: (Width: 36, Height: 26); Text: "-"; Style: @AdjustBtnStyle; }
                Group { Anchor: (Width: 3); }
                TextButton #DetailIn1Up { Anchor: (Width: 36, Height: 26); Text: "+"; Style: @AdjustBtnStyle; }
              }
            }
            Group #DetailIn2 { LayoutMode: Top; Anchor: (Bottom: 4); Visible: false;
              Group { LayoutMode: Left; Anchor: (Height: 28);
                $C.@TextField #DetailIn2Field { FlexWeight: 1; Anchor: (Height: 26); Style: @InputFieldStyle; Background: #1a2633; Padding: (Horizontal: 8); }
                Group { Anchor: (Width: 6); }
                Label { Style: @SubLabelStyle; Anchor: (Width: 30); Text: "Qty"; }
                Label #DetailIn2Qty { Style: @ValueStyle; Anchor: (Width: 50, Height: 24); Background: #061420; Text: "1"; }
                Group { Anchor: (Width: 4); }
                TextButton #DetailIn2Down { Anchor: (Width: 36, Height: 26); Text: "-"; Style: @AdjustBtnStyle; }
                Group { Anchor: (Width: 3); }
                TextButton #DetailIn2Up { Anchor: (Width: 36, Height: 26); Text: "+"; Style: @AdjustBtnStyle; }
              }
            }
            Group #DetailIn3 { LayoutMode: Top; Anchor: (Bottom: 4); Visible: false;
              Group { LayoutMode: Left; Anchor: (Height: 28);
                $C.@TextField #DetailIn3Field { FlexWeight: 1; Anchor: (Height: 26); Style: @InputFieldStyle; Background: #1a2633; Padding: (Horizontal: 8); }
                Group { Anchor: (Width: 6); }
                Label { Style: @SubLabelStyle; Anchor: (Width: 30); Text: "Qty"; }
                Label #DetailIn3Qty { Style: @ValueStyle; Anchor: (Width: 50, Height: 24); Background: #061420; Text: "1"; }
                Group { Anchor: (Width: 4); }
                TextButton #DetailIn3Down { Anchor: (Width: 36, Height: 26); Text: "-"; Style: @AdjustBtnStyle; }
                Group { Anchor: (Width: 3); }
                TextButton #DetailIn3Up { Anchor: (Width: 36, Height: 26); Text: "+"; Style: @AdjustBtnStyle; }
              }
            }
            Group #DetailIn4 { LayoutMode: Top; Anchor: (Bottom: 4); Visible: false;
              Group { LayoutMode: Left; Anchor: (Height: 28);
                $C.@TextField #DetailIn4Field { FlexWeight: 1; Anchor: (Height: 26); Style: @InputFieldStyle; Background: #1a2633; Padding: (Horizontal: 8); }
                Group { Anchor: (Width: 6); }
                Label { Style: @SubLabelStyle; Anchor: (Width: 30); Text: "Qty"; }
                Label #DetailIn4Qty { Style: @ValueStyle; Anchor: (Width: 50, Height: 24); Background: #061420; Text: "1"; }
                Group { Anchor: (Width: 4); }
                TextButton #DetailIn4Down { Anchor: (Width: 36, Height: 26); Text: "-"; Style: @AdjustBtnStyle; }
                Group { Anchor: (Width: 3); }
                TextButton #DetailIn4Up { Anchor: (Width: 36, Height: 26); Text: "+"; Style: @AdjustBtnStyle; }
              }
            }
            Group #DetailIn5 { LayoutMode: Top; Anchor: (Bottom: 4); Visible: false;
              Group { LayoutMode: Left; Anchor: (Height: 28);
                $C.@TextField #DetailIn5Field { FlexWeight: 1; Anchor: (Height: 26); Style: @InputFieldStyle; Background: #1a2633; Padding: (Horizontal: 8); }
                Group { Anchor: (Width: 6); }
                Label { Style: @SubLabelStyle; Anchor: (Width: 30); Text: "Qty"; }
                Label #DetailIn5Qty { Style: @ValueStyle; Anchor: (Width: 50, Height: 24); Background: #061420; Text: "1"; }
                Group { Anchor: (Width: 4); }
                TextButton #DetailIn5Down { Anchor: (Width: 36, Height: 26); Text: "-"; Style: @AdjustBtnStyle; }
                Group { Anchor: (Width: 3); }
                TextButton #DetailIn5Up { Anchor: (Width: 36, Height: 26); Text: "+"; Style: @AdjustBtnStyle; }
              }
            }
            Group { Anchor: (Height: 1); Background: #1e2a36; }
            Group { Anchor: (Height: 4); }
            // Bench
            Group #DetailBenchRow { LayoutMode: Top; Anchor: (Bottom: 4); Visible: false;
              Label { Style: (FontSize: 13, TextColor: #E8A93B, RenderBold: true); Anchor: (Height: 18); Text: "Bench"; }
              Group { LayoutMode: Left; Anchor: (Height: 28);
                $C.@TextField #DetailBenchField { FlexWeight: 1; Anchor: (Height: 26); Style: @InputFieldStyle; Background: #1a2633; Padding: (Horizontal: 8); }
                Group { Anchor: (Width: 6); }
                Label { Style: @SubLabelStyle; Anchor: (Width: 30); Text: "Tier"; }
                Label #DetailBenchTier { Style: @ValueStyle; Anchor: (Width: 50, Height: 24); Background: #061420; Text: "0"; }
                Group { Anchor: (Width: 4); }
                TextButton #DetailTierDown { Anchor: (Width: 36, Height: 26); Text: "-"; Style: @AdjustBtnStyle; }
                Group { Anchor: (Width: 3); }
                TextButton #DetailTierUp { Anchor: (Width: 36, Height: 26); Text: "+"; Style: @AdjustBtnStyle; }
              }
            }
            // Craft Time
            Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
              Label { Style: (FontSize: 13, TextColor: #96a9be, RenderBold: true, VerticalAlignment: Center); Anchor: (Width: 100); Text: "Craft Time"; }
              Label #DetailCraftTime { Style: @ValueStyle; Anchor: (Width: 90, Height: 24); Background: #061420; Text: "5.0s"; }
              Group { Anchor: (Width: 6); }
              TextButton #DetailTimeDown { Anchor: (Width: 40, Height: 28); Text: "-"; Style: @AdjustBtnStyle; }
              Group { Anchor: (Width: 4); }
              TextButton #DetailTimeUp { Anchor: (Width: 40, Height: 28); Text: "+"; Style: @AdjustBtnStyle; }
            }
          }
          Group { Anchor: (Height: 8); }
          TextButton #DetailSave { Anchor: (Width: 140, Height: 32); Text: "Save Recipe"; Style: @ApplyBtnStyle; }
        }
      }

      // ==================== MISC TAB ====================
      Group #ContentMisc {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Padding: (Full: 16);
        Visible: false;

        Label { Style: (FontSize: 16, TextColor: #ffaa4a, RenderBold: true); Anchor: (Height: 24); Text: "Miscellaneous"; }
        Group { Anchor: (Height: 1); Background: #1e2a36; }
        Group { Anchor: (Height: 10); }

        // Instance Rules
        Group { Background: #0b141f(0.84); LayoutMode: Top; Padding: (Full: 12);
          Label { Style: (FontSize: 14, TextColor: #ff5577, RenderBold: true); Anchor: (Height: 20); Text: "Instance Rules"; }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @LabelStyle; FlexWeight: 1; Text: "PvP Enabled"; }
            TextButton #TogglePvp { Anchor: (Width: 80, Height: 28); Text: "OFF"; Style: @ToggleOffStyle; }
          }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @LabelStyle; FlexWeight: 1; Text: "Dungeon Block Protection"; }
            TextButton #ToggleDungeonProt { Anchor: (Width: 80, Height: 28); Text: "ON"; Style: @ToggleOnStyle; }
          }
        }
        Group { Anchor: (Height: 8); }

        // Combo
        Group { Background: #0b141f(0.84); LayoutMode: Top; Padding: (Full: 12);
          Label { Style: (FontSize: 14, TextColor: #ffaa33, RenderBold: true); Anchor: (Height: 20); Text: "Combo Meter"; }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @LabelStyle; FlexWeight: 1; Text: "Enabled"; }
            TextButton #ToggleCombo { Anchor: (Width: 80, Height: 28); Text: "ON"; Style: @ToggleOnStyle; }
          }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @LabelStyle; FlexWeight: 1; Text: "Tier Effects"; }
            TextButton #ToggleComboTierEff { Anchor: (Width: 80, Height: 28); Text: "ON"; Style: @ToggleOnStyle; }
          }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @LabelStyle; FlexWeight: 1; Text: "Decay"; }
            TextButton #ToggleComboDecay { Anchor: (Width: 80, Height: 28); Text: "ON"; Style: @ToggleOnStyle; }
          }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @SubLabelStyle; FlexWeight: 1; Text: "Timer (seconds)"; }
            $C.@TextField #ComboTimer { Anchor: (Width: 70, Height: 24); Style: @InputFieldStyle; Background: #061420; Padding: (Horizontal: 4); }
            Label { Style: (FontSize: 10, TextColor: #6a7a8e, VerticalAlignment: Center); Anchor: (Width: 30); Text: "sec"; }
            Group { Anchor: (Width: 6); }
            TextButton #ComboTimerDown { Anchor: (Width: 40, Height: 28); Text: "-"; Style: @AdjustBtnStyle; }
            Group { Anchor: (Width: 4); }
            TextButton #ComboTimerUp { Anchor: (Width: 40, Height: 28); Text: "+"; Style: @AdjustBtnStyle; }
          }
        }
        Group { Anchor: (Height: 8); }

        // Bounty
        Group { Background: #0b141f(0.84); LayoutMode: Top; Padding: (Full: 12);
          Label { Style: (FontSize: 14, TextColor: #E8A93B, RenderBold: true); Anchor: (Height: 20); Text: "Bounty Board"; }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @LabelStyle; FlexWeight: 1; Text: "Enabled"; }
            TextButton #ToggleBounty { Anchor: (Width: 80, Height: 28); Text: "ON"; Style: @ToggleOnStyle; }
          }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @LabelStyle; FlexWeight: 1; Text: "Streak Bonus"; }
            TextButton #ToggleBountyStreak { Anchor: (Width: 80, Height: 28); Text: "ON"; Style: @ToggleOnStyle; }
          }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @LabelStyle; FlexWeight: 1; Text: "Weekly Bounty"; }
            TextButton #ToggleBountyWeekly { Anchor: (Width: 80, Height: 28); Text: "ON"; Style: @ToggleOnStyle; }
          }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @SubLabelStyle; FlexWeight: 1; Text: "Refresh (hours)"; }
            $C.@TextField #BountyRefresh { Anchor: (Width: 70, Height: 24); Style: @InputFieldStyle; Background: #061420; Padding: (Horizontal: 4); }
            Label { Style: (FontSize: 10, TextColor: #6a7a8e, VerticalAlignment: Center); Anchor: (Width: 29); Text: "hrs"; }
            Group { Anchor: (Width: 6); }
            TextButton #BountyRefreshDown { Anchor: (Width: 40, Height: 28); Text: "-"; Style: @AdjustBtnStyle; }
            Group { Anchor: (Width: 4); }
            TextButton #BountyRefreshUp { Anchor: (Width: 40, Height: 28); Text: "+"; Style: @AdjustBtnStyle; }
          }
        }
        Group { Anchor: (Height: 8); }

        // Warden + Vorthak
        Group { Background: #0b141f(0.84); LayoutMode: Top; Padding: (Full: 12);
          Label { Style: (FontSize: 14, TextColor: #96a9be, RenderBold: true); Anchor: (Height: 20); Text: "Other Features"; }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @LabelStyle; FlexWeight: 1; Text: "Warden Trials"; }
            TextButton #ToggleWarden { Anchor: (Width: 80, Height: 28); Text: "ON"; Style: @ToggleOnStyle; }
          }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @LabelStyle; FlexWeight: 1; Text: "Vorthak Merchant"; }
            TextButton #ToggleVorthak { Anchor: (Width: 80, Height: 28); Text: "ON"; Style: @ToggleOnStyle; }
          }

          // --- Temporal Portals ---
          Group { Anchor: (Height: 8); }
          Label { Style: @LabelStyle; Text: "--- Temporal Portals ---"; }
          Group { Anchor: (Height: 4); }

          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @LabelStyle; FlexWeight: 1; Text: "Temporal Portals"; }
            TextButton #ToggleTemporalPortal { Anchor: (Width: 80, Height: 28); Text: "ON"; Style: @ToggleOnStyle; }
          }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @LabelStyle; FlexWeight: 1; Text: "Portal Duration"; }
            TextButton #PortalDurationDown { Anchor: (Width: 28, Height: 28); Text: "-"; Style: @AdjustBtnStyle; }
            TextField #PortalDuration { Anchor: (Width: 60, Height: 28); Style: @FieldStyle; }
            Label { Style: @UnitStyle; Text: "sec"; }
            TextButton #PortalDurationUp { Anchor: (Width: 28, Height: 28); Text: "+"; Style: @AdjustBtnStyle; }
          }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @LabelStyle; FlexWeight: 1; Text: "Max Concurrent"; }
            TextButton #MaxPortalsDown { Anchor: (Width: 28, Height: 28); Text: "-"; Style: @AdjustBtnStyle; }
            TextField #MaxPortals { Anchor: (Width: 60, Height: 28); Style: @FieldStyle; }
            TextButton #MaxPortalsUp { Anchor: (Width: 28, Height: 28); Text: "+"; Style: @AdjustBtnStyle; }
          }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @LabelStyle; FlexWeight: 1; Text: "Instance Time Limit"; }
            TextButton #InstanceTimeLimitDown { Anchor: (Width: 28, Height: 28); Text: "-"; Style: @AdjustBtnStyle; }
            TextField #InstanceTimeLimit { Anchor: (Width: 60, Height: 28); Style: @FieldStyle; }
            Label { Style: @UnitStyle; Text: "sec"; }
            TextButton #InstanceTimeLimitUp { Anchor: (Width: 28, Height: 28); Text: "+"; Style: @AdjustBtnStyle; }
          }
        }
      }

      // ==================== INTEGRATION TAB ====================
      Group #ContentIntegration {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Padding: (Full: 16);
        Visible: false;

        Label { Style: (FontSize: 16, TextColor: #ffaa4a, RenderBold: true); Anchor: (Height: 24); Text: "Mod Integration"; }
        Label { Style: (FontSize: 12, TextColor: #6a7a8e); Anchor: (Height: 28); Text: "RPG Leveling and Endless Leveling are auto-enabled when detected. Restart required after changes."; }
        Group { Anchor: (Height: 1); Background: #1e2a36; }
        Group { Anchor: (Height: 10); }

        // RPG Leveling
        Group { Background: #0b141f(0.84); LayoutMode: Top; Padding: (Full: 12);
          Label { Style: (FontSize: 14, TextColor: #55ccff, RenderBold: true); Anchor: (Height: 20); Text: "RPG Leveling"; }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @LabelStyle; FlexWeight: 1; Text: "Enabled"; }
            TextButton #ToggleRPGLeveling { Anchor: (Width: 80, Height: 28); Text: "OFF"; Style: @ToggleOffStyle; }
          }
          Label { Style: (FontSize: 11, TextColor: #4a9eff); Anchor: (Height: 16); Text: "Restart required after changing"; }
        }
        Group { Anchor: (Height: 8); }

        // Endless Leveling
        Group { Background: #0b141f(0.84); LayoutMode: Top; Padding: (Full: 12);
          Label { Style: (FontSize: 14, TextColor: #E8A93B, RenderBold: true); Anchor: (Height: 20); Text: "Endless Leveling"; }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @LabelStyle; FlexWeight: 1; Text: "Enabled"; }
            TextButton #ToggleEndlessLeveling { Anchor: (Width: 80, Height: 28); Text: "OFF"; Style: @ToggleOffStyle; }
          }
          Label { Style: (FontSize: 11, TextColor: #4a9eff); Anchor: (Height: 16); Text: "Restart required after changing"; }
        }
        Group { Anchor: (Height: 8); }

        // OrbisGuard
        Group { Background: #0b141f(0.84); LayoutMode: Top; Padding: (Full: 12);
          Label { Style: (FontSize: 14, TextColor: #55ff88, RenderBold: true); Anchor: (Height: 20); Text: "OrbisGuard"; }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @LabelStyle; FlexWeight: 1; Text: "Enabled"; }
            TextButton #ToggleOrbisGuard { Anchor: (Width: 80, Height: 28); Text: "OFF"; Style: @ToggleOffStyle; }
          }
          Label { Style: (FontSize: 11, TextColor: #4a9eff); Anchor: (Height: 16); Text: "Restart required after changing"; }
        }
      }
    }
  }
}

$C.@BackButton {}
