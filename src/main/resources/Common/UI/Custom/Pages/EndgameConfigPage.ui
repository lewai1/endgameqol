$C = "../Common.ui";

// ========== STYLES (MMOSkillTree / EndlessLeveling patterns) ==========

@ToggleOnStyle = TextButtonStyle(
  Default: (Background: #1a3d2e, LabelStyle: (FontSize: 14, TextColor: #4aff7f, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #2a4d3e, LabelStyle: (FontSize: 14, TextColor: #6aff9f, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #0a2d1e, LabelStyle: (FontSize: 14, TextColor: #4aff7f, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Sounds: $C.@ButtonSounds
);
@ToggleOffStyle = TextButtonStyle(
  Default: (Background: #3d1a1a, LabelStyle: (FontSize: 14, TextColor: #ff4a4a, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #4d2a2a, LabelStyle: (FontSize: 14, TextColor: #ff6a6a, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #2d0a0a, LabelStyle: (FontSize: 14, TextColor: #ff4a4a, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Sounds: $C.@ButtonSounds
);

@AdjustBtnStyle = TextButtonStyle(
  Default: (Background: #1a2633, LabelStyle: (FontSize: 14, TextColor: #96a9be, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #2b3542, LabelStyle: (FontSize: 14, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #0a1119, LabelStyle: (FontSize: 14, TextColor: #96a9be, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Sounds: $C.@ButtonSounds
);

@ActionBtnStyle = TextButtonStyle(
  Default: (Background: #2b3542, LabelStyle: (FontSize: 13, TextColor: #96a9be, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #3b4552, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #1b2532, LabelStyle: (FontSize: 13, TextColor: #96a9be, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Sounds: $C.@ButtonSounds
);
@ActionActiveBtnStyle = TextButtonStyle(
  Default: (Background: #1a3d2e, LabelStyle: (FontSize: 13, TextColor: #4aff7f, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #2a4d3e, LabelStyle: (FontSize: 13, TextColor: #6aff9f, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #0a2d1e, LabelStyle: (FontSize: 13, TextColor: #4aff7f, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Sounds: $C.@ButtonSounds
);

@ApplyBtnStyle = TextButtonStyle(
  Default: (Background: #1a3d2e, LabelStyle: (FontSize: 14, TextColor: #4aff7f, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #2a4d3e, LabelStyle: (FontSize: 14, TextColor: #6aff9f, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #0a2d1e, LabelStyle: (FontSize: 14, TextColor: #4aff7f, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Sounds: $C.@ButtonSounds
);

@TabStyle = TextButtonStyle(
  Default: (Background: #0a1119, LabelStyle: (FontSize: 13, TextColor: #96a9be, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #141c26, LabelStyle: (FontSize: 13, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #0a1119, LabelStyle: (FontSize: 13, TextColor: #96a9be, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Sounds: $C.@ButtonSounds
);
@TabActiveStyle = TextButtonStyle(
  Default: (Background: #1a2633, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Hovered: (Background: #1a2633, LabelStyle: (FontSize: 13, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Pressed: (Background: #1a2633, LabelStyle: (FontSize: 13, TextColor: #ffffff, HorizontalAlignment: Center, VerticalAlignment: Center)),
  Sounds: $C.@ButtonSounds
);

// Reusable label styles
@LabelStyle = (FontSize: 14, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
@SubLabelStyle = (FontSize: 13, TextColor: #c0cee5, VerticalAlignment: Center);
@ValueStyle = (FontSize: 14, TextColor: #6fe3ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
@InputFieldStyle = (FontSize: 12, TextColor: #ffffff);

$C.@PageOverlay {
  $C.@DecoratedContainer {
    Anchor: (Width: 950, Height: 700);

    #Title {
      Group {
        $C.@Title {
          @Text = "EndgameQoL Configuration";
        }
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 0);

      // ======== GLOBAL SEARCH ========
      Group #GlobalSearchBar {
        LayoutMode: Left;
        Anchor: (Height: 34);
        Padding: (Horizontal: 10, Vertical: 3);
        $C.@TextField #GlobalSearch { FlexWeight: 1; Anchor: (Height: 28); Style: @InputFieldStyle; Background: #0a1119; Padding: (Horizontal: 8); PlaceholderText: "Search all settings..."; }
        Group { Anchor: (Width: 6); }
        TextButton #GlobalSearchBtn { Anchor: (Width: 76, Height: 28); Text: "Search"; Style: @ApplyBtnStyle; }
        Group { Anchor: (Width: 4); }
        TextButton #GlobalSearchClear { Anchor: (Width: 60, Height: 28); Text: "Clear"; Style: @ActionBtnStyle; }
      }

      // ======== TAB BAR ========
      Group #TabBar {
        LayoutMode: Left;
        Anchor: (Height: 36);

        $C.@TextButton #TabDifficulty { FlexWeight: 1; Anchor: (Height: 32); Text: "Difficulty"; Style: @TabActiveStyle; }
        Group { Anchor: (Width: 2); }
        $C.@TextButton #TabScaling { FlexWeight: 1; Anchor: (Height: 32); Text: "Scaling"; Style: @TabStyle; }
        Group { Anchor: (Width: 2); }
        $C.@TextButton #TabWeapons { FlexWeight: 1; Anchor: (Height: 32); Text: "Weapons"; Style: @TabStyle; }
        Group { Anchor: (Width: 2); }
        $C.@TextButton #TabArmor { FlexWeight: 1; Anchor: (Height: 32); Text: "Armor"; Style: @TabStyle; }
        Group { Anchor: (Width: 2); }
        $C.@TextButton #TabCrafting { FlexWeight: 1; Anchor: (Height: 32); Text: "Crafting"; Style: @TabStyle; }
        Group { Anchor: (Width: 2); }
        $C.@TextButton #TabMisc { FlexWeight: 1; Anchor: (Height: 32); Text: "Misc"; Style: @TabStyle; }
        Group { Anchor: (Width: 2); }
        $C.@TextButton #TabIntegration { FlexWeight: 1; Anchor: (Height: 32); Text: "Integration"; Style: @TabStyle; }
      }
      Group { Anchor: (Height: 1); Background: #2b3542; }

      // ==================== GLOBAL SEARCH RESULTS ====================
      Group #SearchResults {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Padding: (Full: 16);
        Visible: false;

        Label #SearchResultsTitle { Style: (FontSize: 16, TextColor: #ffaa4a, RenderBold: true); Anchor: (Height: 24); Text: "Search Results"; }
        Label #SearchResultsCount { Style: (FontSize: 12, TextColor: #6a7a8e); Anchor: (Height: 16); Text: "0 results"; }
        Group { Anchor: (Height: 1); Background: #1e2a36; }
        Group { Anchor: (Height: 8); }

        Group #SR0 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
          Label #SR0Tab { Style: (FontSize: 11, TextColor: #4a9eff, VerticalAlignment: Center); Anchor: (Width: 90); Text: ""; }
          Label #SR0Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
          Label #SR0Val { Style: @ValueStyle; Anchor: (Width: 90, Height: 24); Background: #061420; Text: ""; }
          Group { Anchor: (Width: 6); }
          TextButton #SR0Btn { Anchor: (Width: 80, Height: 26); Text: "Toggle"; Style: @ActionBtnStyle; }
        }
        Group #SR1 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
          Label #SR1Tab { Style: (FontSize: 11, TextColor: #4a9eff, VerticalAlignment: Center); Anchor: (Width: 90); Text: ""; }
          Label #SR1Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
          Label #SR1Val { Style: @ValueStyle; Anchor: (Width: 90, Height: 24); Background: #061420; Text: ""; }
          Group { Anchor: (Width: 6); }
          TextButton #SR1Btn { Anchor: (Width: 80, Height: 26); Text: "Toggle"; Style: @ActionBtnStyle; }
        }
        Group #SR2 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
          Label #SR2Tab { Style: (FontSize: 11, TextColor: #4a9eff, VerticalAlignment: Center); Anchor: (Width: 90); Text: ""; }
          Label #SR2Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
          Label #SR2Val { Style: @ValueStyle; Anchor: (Width: 90, Height: 24); Background: #061420; Text: ""; }
          Group { Anchor: (Width: 6); }
          TextButton #SR2Btn { Anchor: (Width: 80, Height: 26); Text: "Toggle"; Style: @ActionBtnStyle; }
        }
        Group #SR3 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
          Label #SR3Tab { Style: (FontSize: 11, TextColor: #4a9eff, VerticalAlignment: Center); Anchor: (Width: 90); Text: ""; }
          Label #SR3Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
          Label #SR3Val { Style: @ValueStyle; Anchor: (Width: 90, Height: 24); Background: #061420; Text: ""; }
          Group { Anchor: (Width: 6); }
          TextButton #SR3Btn { Anchor: (Width: 80, Height: 26); Text: "Toggle"; Style: @ActionBtnStyle; }
        }
        Group #SR4 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
          Label #SR4Tab { Style: (FontSize: 11, TextColor: #4a9eff, VerticalAlignment: Center); Anchor: (Width: 90); Text: ""; }
          Label #SR4Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
          Label #SR4Val { Style: @ValueStyle; Anchor: (Width: 90, Height: 24); Background: #061420; Text: ""; }
          Group { Anchor: (Width: 6); }
          TextButton #SR4Btn { Anchor: (Width: 80, Height: 26); Text: "Toggle"; Style: @ActionBtnStyle; }
        }
        Group #SR5 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
          Label #SR5Tab { Style: (FontSize: 11, TextColor: #4a9eff, VerticalAlignment: Center); Anchor: (Width: 90); Text: ""; }
          Label #SR5Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
          Label #SR5Val { Style: @ValueStyle; Anchor: (Width: 90, Height: 24); Background: #061420; Text: ""; }
          Group { Anchor: (Width: 6); }
          TextButton #SR5Btn { Anchor: (Width: 80, Height: 26); Text: "Toggle"; Style: @ActionBtnStyle; }
        }
        Group #SR6 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
          Label #SR6Tab { Style: (FontSize: 11, TextColor: #4a9eff, VerticalAlignment: Center); Anchor: (Width: 90); Text: ""; }
          Label #SR6Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
          Label #SR6Val { Style: @ValueStyle; Anchor: (Width: 90, Height: 24); Background: #061420; Text: ""; }
          Group { Anchor: (Width: 6); }
          TextButton #SR6Btn { Anchor: (Width: 80, Height: 26); Text: "Toggle"; Style: @ActionBtnStyle; }
        }
        Group #SR7 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
          Label #SR7Tab { Style: (FontSize: 11, TextColor: #4a9eff, VerticalAlignment: Center); Anchor: (Width: 90); Text: ""; }
          Label #SR7Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
          Label #SR7Val { Style: @ValueStyle; Anchor: (Width: 90, Height: 24); Background: #061420; Text: ""; }
          Group { Anchor: (Width: 6); }
          TextButton #SR7Btn { Anchor: (Width: 80, Height: 26); Text: "Toggle"; Style: @ActionBtnStyle; }
        }
        Group #SR8 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
          Label #SR8Tab { Style: (FontSize: 11, TextColor: #4a9eff, VerticalAlignment: Center); Anchor: (Width: 90); Text: ""; }
          Label #SR8Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
          Label #SR8Val { Style: @ValueStyle; Anchor: (Width: 90, Height: 24); Background: #061420; Text: ""; }
          Group { Anchor: (Width: 6); }
          TextButton #SR8Btn { Anchor: (Width: 80, Height: 26); Text: "Toggle"; Style: @ActionBtnStyle; }
        }
        Group #SR9 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
          Label #SR9Tab { Style: (FontSize: 11, TextColor: #4a9eff, VerticalAlignment: Center); Anchor: (Width: 90); Text: ""; }
          Label #SR9Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
          Label #SR9Val { Style: @ValueStyle; Anchor: (Width: 90, Height: 24); Background: #061420; Text: ""; }
          Group { Anchor: (Width: 6); }
          TextButton #SR9Btn { Anchor: (Width: 80, Height: 26); Text: "Toggle"; Style: @ActionBtnStyle; }
        }
        Group #SR10 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
          Label #SR10Tab { Style: (FontSize: 11, TextColor: #4a9eff, VerticalAlignment: Center); Anchor: (Width: 90); Text: ""; }
          Label #SR10Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
          Label #SR10Val { Style: @ValueStyle; Anchor: (Width: 90, Height: 24); Background: #061420; Text: ""; }
          Group { Anchor: (Width: 6); }
          TextButton #SR10Btn { Anchor: (Width: 80, Height: 26); Text: "Toggle"; Style: @ActionBtnStyle; }
        }
        Group #SR11 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
          Label #SR11Tab { Style: (FontSize: 11, TextColor: #4a9eff, VerticalAlignment: Center); Anchor: (Width: 90); Text: ""; }
          Label #SR11Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
          Label #SR11Val { Style: @ValueStyle; Anchor: (Width: 90, Height: 24); Background: #061420; Text: ""; }
          Group { Anchor: (Width: 6); }
          TextButton #SR11Btn { Anchor: (Width: 80, Height: 26); Text: "Toggle"; Style: @ActionBtnStyle; }
        }
        Group #SR12 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
          Label #SR12Tab { Style: (FontSize: 11, TextColor: #4a9eff, VerticalAlignment: Center); Anchor: (Width: 90); Text: ""; }
          Label #SR12Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
          Label #SR12Val { Style: @ValueStyle; Anchor: (Width: 90, Height: 24); Background: #061420; Text: ""; }
          Group { Anchor: (Width: 6); }
          TextButton #SR12Btn { Anchor: (Width: 80, Height: 26); Text: "Toggle"; Style: @ActionBtnStyle; }
        }
        Group #SR13 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
          Label #SR13Tab { Style: (FontSize: 11, TextColor: #4a9eff, VerticalAlignment: Center); Anchor: (Width: 90); Text: ""; }
          Label #SR13Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
          Label #SR13Val { Style: @ValueStyle; Anchor: (Width: 90, Height: 24); Background: #061420; Text: ""; }
          Group { Anchor: (Width: 6); }
          TextButton #SR13Btn { Anchor: (Width: 80, Height: 26); Text: "Toggle"; Style: @ActionBtnStyle; }
        }
        Group #SR14 { LayoutMode: Left; Anchor: (Height: 32, Bottom: 2); Background: #0b141f(0.84); Padding: (Horizontal: 10, Vertical: 2); Visible: false;
          Label #SR14Tab { Style: (FontSize: 11, TextColor: #4a9eff, VerticalAlignment: Center); Anchor: (Width: 90); Text: ""; }
          Label #SR14Name { Style: @LabelStyle; FlexWeight: 1; Text: ""; }
          Label #SR14Val { Style: @ValueStyle; Anchor: (Width: 90, Height: 24); Background: #061420; Text: ""; }
          Group { Anchor: (Width: 6); }
          TextButton #SR14Btn { Anchor: (Width: 80, Height: 26); Text: "Toggle"; Style: @ActionBtnStyle; }
        }
      }

      // ==================== DIFFICULTY TAB ====================
      Group #ContentDifficulty {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Padding: (Full: 16);
        Visible: true;

        Label { Style: (FontSize: 16, TextColor: #ffaa4a, RenderBold: true); Anchor: (Height: 24); Text: "Difficulty Settings"; }
        Label { Style: (FontSize: 12, TextColor: #6a7a8e); Anchor: (Height: 16); Text: "Global difficulty preset for bosses and mobs"; }
        Group { Anchor: (Height: 1); Background: #1e2a36; }
        Group { Anchor: (Height: 10); }

        // Preset buttons
        Group {
          Background: #0b141f(0.84); LayoutMode: Left; Anchor: (Height: 48); Padding: (Full: 10);
          Label { Style: @LabelStyle; FlexWeight: 1; Text: "Preset"; }
          TextButton #PresetEasy { Anchor: (Width: 80, Height: 28); Text: "Easy"; Style: @ActionBtnStyle; }
          Group { Anchor: (Width: 6); }
          TextButton #PresetMedium { Anchor: (Width: 90, Height: 28); Text: "Medium"; Style: @ActionBtnStyle; }
          Group { Anchor: (Width: 6); }
          TextButton #PresetHard { Anchor: (Width: 80, Height: 28); Text: "Hard"; Style: @ActionBtnStyle; }
          Group { Anchor: (Width: 6); }
          TextButton #PresetExtreme { Anchor: (Width: 90, Height: 28); Text: "Extreme"; Style: @ActionBtnStyle; }
          Group { Anchor: (Width: 6); }
          TextButton #PresetCustom { Anchor: (Width: 90, Height: 28); Text: "Custom"; Style: @ActionBtnStyle; }
        }
        Group { Anchor: (Height: 6); }

        // Custom multipliers
        Group #CustomBox {
          Background: #0b141f(0.84); LayoutMode: Top; Padding: (Full: 12); Visible: false;
          Label { Style: (FontSize: 14, TextColor: #bb99ff, RenderBold: true); Anchor: (Height: 20); Text: "Custom Multipliers"; }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @SubLabelStyle; FlexWeight: 1; Text: "Health Multiplier"; }
            $C.@TextField #HealthValue { Anchor: (Width: 70, Height: 24); Style: @InputFieldStyle; Background: #061420; Padding: (Horizontal: 4); }
            Label { Style: (FontSize: 10, TextColor: #6a7a8e, VerticalAlignment: Center); Anchor: (Width: 30); Text: "HP"; }
            Group { Anchor: (Width: 4); }
            TextButton #HealthDown { Anchor: (Width: 40, Height: 28); Text: "-"; Style: @AdjustBtnStyle; }
            Group { Anchor: (Width: 4); }
            TextButton #HealthUp { Anchor: (Width: 40, Height: 28); Text: "+"; Style: @AdjustBtnStyle; }
          }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @SubLabelStyle; FlexWeight: 1; Text: "Damage Multiplier"; }
            $C.@TextField #DamageValue { Anchor: (Width: 70, Height: 24); Style: @InputFieldStyle; Background: #061420; Padding: (Horizontal: 4); }
            Label { Style: (FontSize: 10, TextColor: #6a7a8e, VerticalAlignment: Center); Anchor: (Width: 30); Text: "DMG"; }
            Group { Anchor: (Width: 4); }
            TextButton #DamageDown { Anchor: (Width: 40, Height: 28); Text: "-"; Style: @AdjustBtnStyle; }
            Group { Anchor: (Width: 4); }
            TextButton #DamageUp { Anchor: (Width: 40, Height: 28); Text: "+"; Style: @AdjustBtnStyle; }
          }
        }
        Group { Anchor: (Height: 6); }

        // Scope
        Group { Background: #0b141f(0.84); LayoutMode: Left; Anchor: (Height: 44); Padding: (Full: 10);
          Label { Style: (FontSize: 14, TextColor: #96a9be, VerticalAlignment: Center); Anchor: (Width: 80); Text: "Applies to"; }
          Label { Style: @LabelStyle; Anchor: (Width: 60); Text: "Bosses"; }
          TextButton #ToggleBosses { Anchor: (Width: 80, Height: 28); Text: "ON"; Style: @ToggleOnStyle; }
          Group { Anchor: (Width: 20); }
          Label { Style: @LabelStyle; Anchor: (Width: 50); Text: "Mobs"; }
          TextButton #ToggleMobs { Anchor: (Width: 80, Height: 28); Text: "ON"; Style: @ToggleOnStyle; }
        }
        Group { Anchor: (Height: 10); }

        // Reference
        Label { Style: (FontSize: 14, TextColor: #96a9be, RenderBold: true); Anchor: (Height: 20); Text: "Preset Reference"; }
        Group { Anchor: (Height: 4); }
        Group { LayoutMode: Top; Background: #0b141f(0.84); Padding: (Full: 10);
          Group { LayoutMode: Left; Anchor: (Height: 18); Label { Style: (FontSize: 12, TextColor: #55ff55, RenderBold: true); Anchor: (Width: 90); Text: "Easy"; } Label { Style: (FontSize: 12, TextColor: #96a9be); FlexWeight: 1; Text: "HP x0.5 / DMG x0.5"; } }
          Group { LayoutMode: Left; Anchor: (Height: 18); Label { Style: (FontSize: 12, TextColor: #ffff55, RenderBold: true); Anchor: (Width: 90); Text: "Medium"; } Label { Style: (FontSize: 12, TextColor: #96a9be); FlexWeight: 1; Text: "HP x1.0 / DMG x1.0"; } }
          Group { LayoutMode: Left; Anchor: (Height: 18); Label { Style: (FontSize: 12, TextColor: #ff8833, RenderBold: true); Anchor: (Width: 90); Text: "Hard"; } Label { Style: (FontSize: 12, TextColor: #96a9be); FlexWeight: 1; Text: "HP x1.5 / DMG x1.25"; } }
          Group { LayoutMode: Left; Anchor: (Height: 18); Label { Style: (FontSize: 12, TextColor: #ff3333, RenderBold: true); Anchor: (Width: 90); Text: "Extreme"; } Label { Style: (FontSize: 12, TextColor: #96a9be); FlexWeight: 1; Text: "HP x2.5 / DMG x2.0"; } }
          Group { LayoutMode: Left; Anchor: (Height: 18); Label { Style: (FontSize: 12, TextColor: #bb99ff, RenderBold: true); Anchor: (Width: 90); Text: "Custom"; } Label { Style: (FontSize: 12, TextColor: #96a9be); FlexWeight: 1; Text: "Set your own values"; } }
        }
      }

      // ==================== SCALING TAB ====================
      Group #ContentScaling {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Padding: (Full: 16);
        Visible: false;

        Label { Style: (FontSize: 16, TextColor: #ffaa4a, RenderBold: true); Anchor: (Height: 24); Text: "Boss & Mob Scaling"; }
        Label { Style: (FontSize: 12, TextColor: #6a7a8e); Anchor: (Height: 16); Text: "Override health, damage, and player scaling per boss"; }
        Group { Anchor: (Height: 1); Background: #1e2a36; }
        Group { Anchor: (Height: 10); }

        // Prisma toggles
        Group { Background: #0b141f(0.84); LayoutMode: Top; Padding: (Full: 12);
          Label { Style: (FontSize: 14, TextColor: #bb88ff, RenderBold: true); Anchor: (Height: 20); Text: "Prisma Balance"; }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @LabelStyle; FlexWeight: 1; Text: "Prisma Armor Vulnerability"; }
            TextButton #TogglePrismaArmor { Anchor: (Width: 80, Height: 28); Text: "ON"; Style: @ToggleOnStyle; }
          }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
            Label { Style: @LabelStyle; FlexWeight: 1; Text: "Prisma Weapon Boss Block"; }
            TextButton #TogglePrismaWeapon { Anchor: (Width: 80, Height: 28); Text: "ON"; Style: @ToggleOnStyle; }
          }
        }
        Group { Anchor: (Height: 10); }

        // Boss cards
        Group #BossDragonFrost { Background: #0b141f(0.84); LayoutMode: Top; Padding: (Full: 12);
          Label { Style: (FontSize: 14, TextColor: #55ccff, RenderBold: true); Anchor: (Height: 20); Text: "Dragon Frost"; }
          Group { LayoutMode: Left; Anchor: (Height: 32, Bottom: 4);
