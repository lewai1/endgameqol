$C = "../Common.ui";

$C.@PageOverlay {}

$C.@DecoratedContainer {
  Anchor: (Width: 650, Height: 550);

  #Title {
    Group {
      $C.@Title {
        @Text = "Trade";
      }
    }
  }

  #Content {
    LayoutMode: Top;
    Padding: (Full: 10);

    // Merchant info bar
    Group #MerchantBar {
      LayoutMode: Left;
      Anchor: (Height: 32);
      Padding: (Bottom: 6);

      Label #MerchantName {
        Style: (FontSize: 18, TextColor: #E8A93B, RenderBold: true, VerticalAlignment: Center);
        FlexWeight: 1;
      }

      Label #CurrencyInfo {
        Style: (FontSize: 14, TextColor: #96a9be, VerticalAlignment: Center, HorizontalAlignment: End);
        Anchor: (Width: 180);
      }
    }

    // Separator
    Group {
      Anchor: (Height: 1);
      Background: #ffffff(0.08);
    }

    // Trade list
    Group #TradeList {
      FlexWeight: 1;
      LayoutMode: TopScrolling;
      ScrollbarStyle: $C.@DefaultScrollbarStyle;
      Padding: (Top: 6);
    }

    // Notification bar (bottom)
    Group #NotifBar {
      Anchor: (Height: 28);
      Padding: (Top: 4);
      Visible: false;

      Label #NotifText {
        Style: (FontSize: 14, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
        Anchor: (Height: 24);
        Background: #000000(0.4);
      }
    }
  }
}

$C.@BackButton {}
